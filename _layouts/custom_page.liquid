<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{{ page.title }} | {{ site.first_name }} {{ site.last_name }}</title>
    <meta name="author" content="{{ site.first_name }} {{ site.last_name }}">
    <meta name="description" content="{{ page.description | default: site.description }}">
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    {% if site.icon != blank %}
      <link rel="shortcut icon" href="{{ site.icon | prepend: '/assets/img/' | relative_url }}">
    {% endif %}
    
    <style>
      :root {
        --primary: #2563eb;
        --primary-dark: #1d4ed8;
        --primary-light: #dbeafe;
        --accent: #7c3aed;
        --accent-light: #ede9fe;
        --text: #1f2937;
        --text-light: #6b7280;
        --bg: #ffffff;
        --bg-alt: #f9fafb;
        --border: #e5e7eb;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
      }
      
      * { margin: 0; padding: 0; box-sizing: border-box; }
      
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        line-height: 1.6;
        color: var(--text);
        background: var(--bg);
      }
      
      .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
      
      /* Header with animated gradient background */
      header {
        padding: 30px 0 20px;
        background: linear-gradient(270deg, #f8fafc, #e2e8f0);
        background-size: 400% 400%;
        -webkit-animation: AnimationName 30s ease infinite;
        -moz-animation: AnimationName 30s ease infinite;
        animation: AnimationName 30s ease infinite;
        border-bottom: 1px solid var(--border);
      }
      
      @-webkit-keyframes AnimationName {
        0%{background-position:0% 50%}
        50%{background-position:100% 50%}
        100%{background-position:0% 50%}
      }
      @-moz-keyframes AnimationName {
        0%{background-position:0% 50%}
        50%{background-position:100% 50%}
        100%{background-position:0% 50%}
      }
      @keyframes AnimationName {
        0%{background-position:0% 50%}
        50%{background-position:100% 50%}
        100%{background-position:0% 50%}
      }
      
      .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .site-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
      }
      
      .site-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }
      
      .site-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text);
      }
      
      .site-brand:hover .site-title {
        color: var(--primary);
      }
      
      /* Navigation */
      nav { background: var(--bg); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
      nav ul { display: flex; gap: 32px; list-style: none; padding: 16px 0; margin: 0; }
      nav a { color: var(--text); text-decoration: none; font-weight: 500; padding: 8px 0; border-bottom: 2px solid transparent; transition: all 0.2s; }
      nav a:hover, nav a.active { color: var(--primary); border-bottom-color: var(--primary); }
      
      /* Page Title */
      .page-header {
        padding: 40px 0 20px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 30px;
      }
      
      .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text);
      }
      
      /* Main Content */
      main {
        padding: 20px 0 60px;
        min-height: calc(100vh - 300px);
      }
      
      /* Publications Styles */
      .publications {
        margin-top: 20px;
      }
      
      .bibliography {
        list-style: none;
        padding: 0;
      }
      
      .bibliography li {
        margin-bottom: 30px;
        padding-bottom: 30px;
        border-bottom: 1px solid var(--border);
      }
      
      .bibliography li:last-child {
        border-bottom: none;
      }
      
      /* Year headers hidden */
      h2.bibliography {
        display: none;
      }
      
      /* Publication Item */
      .row {
        display: flex;
        gap: 20px;
      }
      
      .col-sm-2 {
        flex: 0 0 100px;
      }
      
      .col-sm-8, .col-sm-10 {
        flex: 1;
      }
      
      /* Badge */
      .badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        color: white;
        text-align: center;
        margin-bottom: 8px;
      }
      
      .badge a {
        color: white;
        text-decoration: none;
      }
      
      .rounded {
        border-radius: 6px;
      }
      
      .w-100 {
        width: 100%;
      }
      
      /* Title */
      .title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
        line-height: 1.4;
      }
      
      /* Author */
      .author {
        font-size: 0.95rem;
        color: var(--text-light);
        margin-bottom: 6px;
      }
      
      .author em {
        color: var(--text);
        font-style: normal;
        font-weight: 500;
      }
      
      .author a {
        color: var(--primary);
        text-decoration: none;
      }
      
      .author a:hover {
        text-decoration: underline;
      }
      
      /* More authors span */
      .more-authors {
        color: var(--primary);
        cursor: pointer;
        text-decoration: underline;
      }
      
      /* Periodical */
      .periodical {
        font-size: 0.9rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 10px;
      }
      
      /* Links/Buttons */
      .links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
      }
      
      .links a {
        display: inline-block;
        padding: 4px 12px;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.85rem;
        color: var(--text);
        text-decoration: none;
        background: var(--bg-alt);
        transition: all 0.2s;
      }
      
      .links a:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }
      
      /* Abstract button */
      .abstract {
        cursor: pointer;
      }
      
      /* Hidden blocks */
      .hidden {
        display: none;
      }
      
      .abstract.hidden, .bibtex.hidden {
        margin-top: 15px;
        padding: 15px;
        background: var(--bg-alt);
        border-radius: 6px;
        font-size: 0.95rem;
        line-height: 1.6;
      }
      
      .abstract.hidden p {
        margin: 0;
      }
      
      /* Abstract content block with minimal styling */
      .abstract-content, .cite-content {
        margin-top: 15px;
        padding: 16px 20px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--text);
      }
      
      .abstract-content p {
        margin: 0;
      }
      
      .cite-content pre {
        margin: 0;
        background: transparent;
      }
      
      /* Footer */
      footer {
        padding: 40px 0;
        text-align: center;
        border-top: 1px solid var(--border);
        color: var(--text-light);
        font-size: 0.9rem;
      }
      
      /* 响应式 */
      @media (max-width: 768px) {
        .row {
          flex-direction: column;
          gap: 10px;
        }
        
        .col-sm-2 {
          flex: 0 0 auto;
          width: auto;
        }
        
        .badge {
          width: auto;
          display: inline-flex;
        }
      }
    </style>
  </head>

  <!-- Body -->
  <body>
    <!-- Header -->
    <header>
      <div class="container">
        <div class="header-content">
          <a href="{{ '/' | relative_url }}" class="site-brand">
            <img src="{{ '/assets/img/wty.png' | relative_url }}" alt="{{ site.first_name }} {{ site.last_name }}" class="site-avatar">
            <span class="site-title">{{ site.first_name }} {{ site.last_name }}</span>
          </a>
        </div>
      </div>
    </header>

    <!-- Navigation -->
    <nav>
      <div class="container">
        <ul>
          <li><a href="{{ '/' | relative_url }}">Overview</a></li>
          <li><a href="{{ '/publications/' | relative_url }}" class="active">Publications</a></li>
        </ul>
      </div>
    </nav>

    <!-- Content -->
    <main class="container">
      {{ content }}
    </main>

    <!-- Footer -->
    <footer>
      <div class="container">
        <p>© 2025 {{ site.first_name }} {{ site.last_name }} | Ph.D. Student at Zhejiang University</p>
      </div>
    </footer>

    <script>
      // Abstract toggle functionality
      document.querySelectorAll('.abstract-toggle').forEach(btn => {
        btn.addEventListener('click', function() {
          const row = this.closest('.row');
          const abstractContent = row.querySelector('.abstract-content');
          if (abstractContent) {
            abstractContent.classList.toggle('hidden');
          }
        });
      });

      // Cite toggle functionality
      document.querySelectorAll('.cite-toggle').forEach(btn => {
        btn.addEventListener('click', function() {
          const row = this.closest('.row');
          const citeContent = row.querySelector('.cite-content');
          if (citeContent) {
            citeContent.classList.toggle('hidden');
          }
        });
      });
    </script>
  </body>
</html>
