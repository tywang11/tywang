<!-- jQuery -->
<script
  src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
  crossorigin="anonymous"
></script>

<!-- Bootsrap & MDB scripts -->
<script src="{{ '/assets/js/bootstrap.bundle.min.js' | relative_url }}"></script>
<script
  src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/7.2.0/mdb.umd.min.js"
  crossorigin="anonymous"
></script>

<!-- Common JS -->
<script src="{{ '/assets/js/common.js' | relative_url | bust_file_cache }}"></script>

{% if site.enable_darkmode %}
  <script src="{{ '/assets/js/theme.js' | relative_url | bust_file_cache }}"></script>
{% endif %}

<!-- Copy code button -->
<script src="{{ '/assets/js/copy_code.js' | relative_url | bust_file_cache }}"></script>

{% if site.search_enabled %}
  <!-- Search -->
  <script src="{{ '/assets/js/search/base-styles.min.js' | relative_url | bust_file_cache }}"></script>
  <script src="{{ '/assets/js/search/command-score.min.js' | relative_url | bust_file_cache }}"></script>
  <script type="module" src="{{ '/_scripts/search.liquid.js' | relative_url | bust_file_cache }}"></script>
{% endif %}

<!-- MathJax -->
{% if site.enable_math %}
  <script src="{{ '/assets/js/mathjax-setup.js' | relative_url | bust_file_cache }}"></script>
  <script
    id="MathJax-script"
    async
    src="https://cdn.jsdelivr.net/npm/mathjax@3.2.2/es5/tex-mml-chtml.min.js"
    crossorigin="anonymous"
  ></script>
{% endif %}

<!-- Medium Zoom -->
<script
  defer
  src="https://cdn.jsdelivr.net/npm/medium-zoom@1.1.0/dist/medium-zoom.min.js"
  crossorigin="anonymous"
></script>
<script defer src="{{ '/assets/js/zoom.js' | relative_url | bust_file_cache }}"></script>

<!-- Bootstrap Table -->
{% if page.pretty_table %}
  <script src="{{ '/assets/js/bootstrap-toc.min.js' | relative_url }}"></script>
{% endif %}
