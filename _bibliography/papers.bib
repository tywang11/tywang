@inproceedings{wang2025underload,
  abbr={CVPR},
  title={Can't Slow Me Down: Learning Robust and Hardware-Adaptive Object Detectors against Latency Attacks for Edge Devices},
  author={Wang, Tianyi and Wang, Zichen and Wang, Cong and Shu, Yuanchao and Deng, Ruilong and Cheng, Peng and Chen, Jiming},
  booktitle={Proceedings of the Computer Vision and Pattern Recognition Conference},
  pages={19230--19240},
  selected={true},
  abstract={Latency attacks pose a critical threat to real-time object detection systems on edge devices by generating phantom objects that congest the NMS pipeline. This paper proposes Underload, a hardware-adaptive, background-attentive adversarial training mechanism that achieves favorable balance between clean and robust accuracy. Our defense restores real-time processing capability from 13 FPS to 43 FPS on Jetson Orin NX, with 8-10% improvement in robust accuracy compared to existing defenses.},
  pdf={underload.pdf},
  code={https://github.com/Hill-Wu-1998/underload},
  keywords={adversarial machine learning, object detection, edge computing, latency attacks}
  year={2025}
}

